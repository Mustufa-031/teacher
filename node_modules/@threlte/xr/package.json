  "description": "Tools to more easily create VR and AR experiences with Threlte",
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@sveltejs/adapter-auto": "^6.1.0",
    "@sveltejs/kit": "^2.37.0",
    "@sveltejs/package": "^2.3.7",
    "@sveltejs/vite-plugin-svelte": "^6.1.4",
    "@types/three": "^0.175.0",
    "@types/webxr": "0.5.23",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.26.0",
    "eslint-plugin-svelte": "^3.5.1",
    "globals": "^16.1.0",
    "postcss": "^8.4.38",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "publint": "^0.2.7",
    "svelte": "5.53.6",
    "svelte-check": "^4.3.1",
    "three": "^0.175.0",
    "tslib": "^2.6.2",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.32.0",
    "vite": "^7.1.4",
    "vite-plugin-mkcert": "^1.17.5",
    "@threlte/core": "8.5.14",
    "@threlte/extras": "9.16.0"
  },
  "peerDependencies": {
    "svelte": ">=5",
    "three": ">=0.160"
  },
  "type": "module",
  "keywords": [
    "webxr",
    "vr",
    "ar",
    "threlte",
    "svelte",
    "three",
    "three.js",
    "3d"
  ],
  "homepage": "https://threlte.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/threlte/threlte",
    "directory": "packages/xr"
  },
  "bugs": {
    "url": "https://github.com/threlte/threlte/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.js",
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "scripts": {
    "dev": "vite dev --host",
    "package": "svelte-kit sync && svelte-package && node ./scripts/cleanupPackage.js && publint",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "cleanup": "rimraf node_modules .svelte-kit dist"
  }
}